# 后端配置
PORT=8080
# Postgres 连接串（与 db/docker-compose.yml 一致）
DATABASE_URL=postgres://crm:crm@localhost:5432/nextcrm
# 当前登录用户/租户（演示用；生产应来自鉴权中间件）
DEFAULT_ORG_ID=1
DEFAULT_USER_ID=1
# 允许的前端来源（CORS），逗号分隔；也是企业微信回调 postMessage 目标
CORS_ORIGIN=http://localhost:5173

# JWT
JWT_SECRET=change-me-in-prod
JWT_ACCESS_TTL=2h
JWT_REFRESH_TTL=7d

# 企业微信 SSO（留空则进入开发模拟模式，扫码直接以演示账号登录）
# 后端回调基址（企业微信后台「可信域名/回调」需配置为浏览器可达地址）
SELF_BASE_URL=http://localhost:8080
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_SECRET=

# 企查查工商关系 API（用于按集团/实控人自动归集公司）；留空则用 company_relation 表 + 字号兜底
QCC_API_BASE=https://api.qcc.com
QCC_API_KEY=
